NODE_ENV=development
PORT=5000

# Use a single literal URL (dotenv does not expand ${VAR} inside values).
DATABASE_URL="postgresql://postgres:password123@localhost:5432/social_commerce?schema=public"

# Optional: Redis for Socket.IO adapter + livestream viewer counts. Omit both lines for local dev without Redis.
# REDIS_URL="redis://:your_redis_password_here@localhost:6379"

# Each value must be exactly 32 hexadecimal characters (as shown in Agora Console) for RTC token v2.
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# Razorpay (INR). Test keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret from Razorpay dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3000

JWT_ACCESS_SECRET=your_access_token_secret_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_chars

JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d